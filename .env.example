# Copy to .env. Point this at your FusionOCR project folder (the one with main.py
# exposing run_ocr). Leave it unset to run the tester on mock data.
# Windows example:
#   FUSIONOCR_PATH=Z:\Code\Python\FusionOCR
# Linux/Mac example:
#   FUSIONOCR_PATH=/home/you/code/FusionOCR
FUSIONOCR_PATH=./fusionocr
